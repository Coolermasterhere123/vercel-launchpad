# Rename this file to .env.local for local dev
# In Vercel: Settings → Environment Variables → add MY_VERCEL_TOKEN
#
# IMPORTANT: Do NOT name this VERCEL_TOKEN — Vercel reserves that name
# and will silently block it from being injected into your app.
#
# Generate a token at: https://vercel.com/account/tokens
MY_VERCEL_TOKEN=your_vercel_personal_access_token_here
